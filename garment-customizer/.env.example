# 阿里云百炼 / DashScope API 配置
# 获取 API Key: https://dashscope.console.aliyun.com/

# AI Provider 选择
VITE_AI_PROVIDER=qwen

# API Key (请替换为你的真实 API Key)
VITE_AI_API_KEY=your_dashscope_api_key_here

# 图像生成模型 (默认: qwen-image-2.0-pro)
# 可选: qwen-image-2.0 (速度快), qwen-image-2.0-pro (高质量)
VITE_AI_MODEL=qwen-image-2.0-pro

# 输出图片尺寸 (默认: 720*720)
# 可选: 512*512, 720*720, 1024*1024
VITE_AI_SIZE=720*720
